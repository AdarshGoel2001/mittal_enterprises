# Resend API key — create one at https://resend.com/api-keys
RESEND_API_KEY=
# Recipient address that receives contact + enquiry form submissions
CONTACT_EMAIL=
# From address for outgoing mail; must be a verified Resend sender (default works for testing)
MAIL_FROM=Mittal Enterprises <onboarding@resend.dev>

# Optional: Upstash Redis REST credentials. When BOTH are set, the chat rate
# limiter switches from in-memory (per-instance) to a distributed sliding window
# (consistent across Vercel lambdas). Leave blank to keep in-memory behavior.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
